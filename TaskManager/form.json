{
  "elements": [
    {
      "type": "Label",
      "caption": "Task Manager – Einstellungen"
    },
    {
      "type": "CheckBox",
      "name": "DarkMode",
      "caption": "Dunkles Design"
    },
    {
      "type": "CheckBox",
      "name": "ShowStats",
      "caption": "Statistik-Leiste anzeigen"
    },
    {
      "type": "NumberSpinner",
      "name": "MaxCompletedVisible",
      "caption": "Max. erledigte Aufgaben anzeigen",
      "minimum": 0,
      "maximum": 100
    },
    {
      "type": "Select",
      "name": "FontSize",
      "caption": "Schriftgröße",
      "options": [
        { "caption": "Klein (12px)",   "value": 12 },
        { "caption": "Normal (14px)",  "value": 14 },
        { "caption": "Groß (16px)",    "value": 16 },
        { "caption": "Sehr groß (18px)", "value": 18 }
      ]
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Alle erledigten löschen",
      "onClick": "TM_DeleteAllCompleted($id);"
    },
    {
      "type": "Button",
      "caption": "Ansicht aktualisieren",
      "onClick": "TM_Refresh($id);"
    }
  ],
  "status": []
}
